# Server Environment Variables
# Copy this file to .env and fill in the values

# Port for the Express server (Render sets this automatically)
PORT=3001

# Secret key for JWT token signing - CHANGE THIS in production!
JWT_SECRET=your-super-secret-key-change-me

# Comma-separated list of allowed CORS origins
# For production, set to your frontend URL, e.g. https://your-app.vercel.app
# Use * to allow all origins (useful when frontend is served by same server)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
